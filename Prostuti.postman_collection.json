                  "    pm.expect(responseData.message).to.be.a('string');\r",
                  "});\r",
                  "\r",
                  "// A4.3 - Deep Body Field Assertions (Full Data Integrity Check)\r",
                  "pm.test(\"A4.3 - Returned fields dynamically match the updated request body\", function () {\r",
                  "    var updatedItem = responseData.data;\r",
                  "\r",
                  "    // 1. Prove the ID is identical to our original item\r",
                  "    pm.expect(updatedItem.id).to.eql(Number(pm.environment.get(\"id\")));\r",
                  "\r",
                  "    // 2. Prove the PATCH update actually applied\r",
                  "    pm.expect(updatedItem.status).to.eql(requestData.status);\r",
                  "\r",
                  "    // 3. Data Integrity: Assert that core fields still exist and hold valid values\r",
                  "    pm.expect(updatedItem).to.have.property('title');\r",
                  "    pm.expect(updatedItem.title).to.be.a('string');\r",
                  "    \r",
                  "    pm.expect(updatedItem).to.have.property('priority');\r",
                  "    pm.expect(updatedItem.priority).to.be.a('number').within(1, 5);\r",
                  "\r",
                  "    pm.expect(updatedItem).to.have.property('description');\r",
                  "    if (updatedItem.description) {\r",
                  "        pm.expect(updatedItem.description).to.be.a('string');\r",
                  "    }\r",
                  "\r",
                  "    // 4. Check that the server updated the modification timestamp\r",
                  "    pm.expect(updatedItem).to.have.property('updated_at');\r",
                  "});"
