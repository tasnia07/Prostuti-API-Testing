                  "pm.test(\"A1.2 - Success wrapper includes data and message\", function () {\r",
                  "    pm.expect(responseData).to.have.property('data');\r",
                  "    pm.expect(responseData).to.have.property('message');\r",
                  "    pm.expect(responseData.message).to.be.a('string');\r",
                  "});\r",
                  "\r",
                  "// 3. Assert response body 'data' is an array\r",
                  "pm.test(\"A1.3 - Response contains a collection of items\", function () {\r",
                  "    pm.expect(responseData.data.data).to.be.an('array');\r",
                  "});\r",
