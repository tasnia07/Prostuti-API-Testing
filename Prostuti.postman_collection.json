    {
      "name": "Section-C",
      "item": [
        {
          "name": "C1-Data-driven field validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse the sent request body\r",
                  "const requestBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// 2. Programmatically determine which field was broken and assign its task number\r",
                  "let taskNumber = \"C1.unknown\";\r",
                  "let detectedBrokenField = \"unknown\";\r",
                  "\r",
                  "if (requestBody.name.length < 3 || requestBody.name.length > 50) {\r",
                  "    taskNumber = \"C1.1\";\r",
                  "    detectedBrokenField = \"name\";\r",
                  "} else if (requestBody.age < 18 || requestBody.age > 100) {\r",
                  "    taskNumber = \"C1.2\";\r",
                  "    detectedBrokenField = \"age\";\r",
                  "} else if (requestBody.phone.length < 11 || !requestBody.phone.startsWith(\"01\")) {\r",
                  "    taskNumber = \"C1.3\";\r",
                  "    detectedBrokenField = \"phone\";\r",
                  "} else if (requestBody.terms !== true) {\r",
                  "    taskNumber = \"C1.4\";\r",
                  "    detectedBrokenField = \"terms\";\r",
                  "}\r",
                  "\r",
                  "// 3. Exactly 2 assertions per iteration\r",
                  "pm.test(`[${taskNumber}] - Status code is 422 Unprocessable Entity`, function () {\r",
                  "    pm.response.to.have.status(422);\r",
                  "});\r",
                  "\r",
                  "pm.test(`[${taskNumber}] - Errors object contains entry for: \"${detectedBrokenField}\"`, function () {\r",
                  "    const responseJson = pm.response.json();\r",
                  "    pm.expect(responseJson).to.have.property('errors');\r",
                  "    pm.expect(responseJson.errors).to.have.property(detectedBrokenField);\r",
                  "});\r",
                  "\r",
                  "// 4. LOOP CONTROL: Read index, increment it safely\r",
                  "let currentIteration = pm.collectionVariables.get(\"currentIteration\");\r",
                  "\r",
                  "if (currentIteration === undefined || currentIteration === null || currentIteration === \"\") {\r",
                  "    currentIteration = 0;\r",
                  "} else {\r",
                  "    currentIteration = parseInt(currentIteration, 10);\r",
                  "}\r",
                  "\r",
                  "currentIteration++;\r",
                  "\r",
                  "// 5. FIX: Use classic postman.setNextRequest for universal Newman compatibility\r",
                  "if (currentIteration < 4) {\r",
                  "    pm.collectionVariables.set(\"currentIteration\", currentIteration);\r",
                  "    postman.setNextRequest(pm.info.requestName); \r",
