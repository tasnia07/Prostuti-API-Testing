                "exec": [
                  "// Parse the JSON response globally\r",
                  "var responseData = pm.response.json();\r",
                  "var requestData = JSON.parse(pm.request.body);\r",
                  "\r",
                  "// B2.1 - Assert status code is 422 Unprocessable Entity\r",
                  "pm.test(\"B2.1 - Status code is 422 Unprocessable Entity\", function () {\r",
                  "    pm.response.to.have.status(422);\r",
                  "});\r",
                  "\r",
                  "// B2.2 - Explicitly assert that the response has an errors object\r",
                  "pm.test(\"B2.2 - Response contains a valid errors object\", function () {\r",
                  "    pm.expect(responseData).to.have.property('errors');\r",
                  "    pm.expect(responseData.errors).to.be.an('object'); \r",
                  "});\r",
                  "\r",
                  "// B3.3 - Dynamic Request Body Boundary Evaluation for Name, Age, and Phone\r",
                  "pm.test(\"B2.3 - Sent payload fields sit exactly on valid table boundary limits\", function () {\r",
                  "    pm.expect(responseData.errors).to.have.property('name');\r",
                  "    pm.expect(responseData.errors).to.have.property('age');\r",
                  "    pm.expect(responseData.errors).to.have.property('phone');\r",
                  "\r",
                  " // 1. Evaluate Name boundary rule (3–50 characters inclusive)\r",
                  "    var nameLength = requestData.name.length;\r",
                  "    var isNameLengthInvalid = (nameLength < 3 || nameLength > 50);\r",
                  "    pm.expect(isNameLengthInvalid, \"Name length should be outside the valid 3-50 range\").to.be.true;\r",
                  "    pm.expect(responseData.errors).to.have.property('name');\r",
                  "    \r",
                  "    // 2. Evaluate Age boundary rule (Integer, strictly 18 or above)\r",
                  "var ageValue = Number(requestData.age);\r",
                  "    var isAgeInvalid = (ageValue < 18 || ageValue > 100);\r",
                  "    pm.expect(isAgeInvalid, \"Age value should be outside the valid 18-100 range to trigger failure\").to.be.true;\r",
                  "    \r",
                  "    // 3. Evaluate Phone rule - Condition 1: Must be exactly 11 characters long\r",
                  "    var phoneLength = requestData.phone.length;\r",
                  "    var startsWith01 = requestData.phone.startsWith(\"01\");\r",
                  "    var isPhoneInvalid = (phoneLength !== 11 || !startsWith01);\r",
                  "    pm.expect(isPhoneInvalid, \"Phone number should fail length or prefix rules\").to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
