        {
          "name": "A2-Create an item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Dynamically store the id\r",
                  "\r",
                  "var responseData = pm.response.json();\r",
                  "pm.environment.set(\"id\", responseData.data.id)\r",
                  "\r",
                  "// Dynamically parse the outbound Request Body\r",
                  "var requestData = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// A2.1 - Assert status code is 201 Created\r",
                  "pm.test(\"A2.1 - Status Code is 201 Created\", function (){\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// A2.2 - Verify the global envelope structure\r",
                  "pm.test(\"A2.2 - Success wrapper includes data and message\", function () {\r",
                  "    pm.expect(responseData).to.have.property('data');\r",
                  "    pm.expect(responseData).to.have.property('message');\r",
                  "    pm.expect(responseData.message).to.be.a('string');\r",
                  "});\r",
                  "\r",
                  "// A2.3 - Assert response contains a generated ID\r",
                  "pm.test(\"A2.3 - Response contains a generated id\", function () {\r",
                  "    pm.expect(responseData.data).to.have.property('id');\r",
                  "});\r",
                  "\r",
                  "// A2.4 - DYNAMIC ASSERTION: Matches request body directly with response body\r",
                  "pm.test(\"A2.4 - Returned fields dynamically match the sent request body\", function () {\r",
                  "    pm.expect(responseData.data.title).to.eql(requestData.title);\r",
                  "    pm.expect(responseData.data.status).to.eql(requestData.status);\r",
                  "    pm.expect(responseData.data.priority).to.eql(requestData.priority);\r",
                  "    \r",
                  "    // Dynamically checks description if it was provided in the request\r",
                  "    if (requestData.description) {\r",
                  "        pm.expect(responseData.data.description).to.eql(requestData.description);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
